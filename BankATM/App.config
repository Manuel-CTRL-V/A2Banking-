<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<appSettings>
		<add key="BankApiBaseUrl"  value="http://localhost:5249/api/" />
		<add key="ATM_Identifier"  value="ATM-001" />
		<add key="LogFilePath"     value="atm_log.txt" />
		<add key="RequestTimeout"  value="30" />
	</appSettings>
</configuration>
